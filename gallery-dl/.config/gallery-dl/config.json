{
  "extractor": {
    "base-directory": "/home/moon/Downloads/gallery-dl",
    "archive": "/home/moon/.local/share/gallery-dl/archive.sqlite3",
    "skip": true,
    "path-restrict": "windows+",
    "path-strip": "auto",
    "cookies-update": true,

    "twitter": {
      "cookies": [
        "firefox",
        "/home/moon/.var/app/io.gitlab.librewolf-community/.librewolf/swh32wvy.default-default",
        null,
        "all"
      ],
      "size": ["large", "medium", "small"],
      "timeline": {
        "strategy": "tweets"
      },
      "text-tweets": false,
      "retweets": false,
      "videos": true,
      "pinned": false,
      "directory": ["x", "{author[name]}"],
      "filename": "{tweet_id}_{author[name]}_{num}.{extension}",
      "postprocessors": [
        {
          "name": "metadata",
          "event": "post",
          "mode": "custom",
          "filename": "{tweet_id}_{author[name]}.txt",
          "content-format": "{content}\n"
        }
      ]
    },
    
    "instagram": {
      "cookies": [
        "firefox",
        "/home/moon/.var/app/io.gitlab.librewolf-community/.librewolf/swh32wvy.default-default",
        null,
        null,
        ".instagram.com"
      ],
      "browser": "firefox",
      "include": ["reels"],
      "videos": "ytdl",
      "directory": ["instagram", "{username}", "reels"],
      "filename": "{media_id}_{shortcode}.{extension}"
    },
    
    "reddit": {
      "videos": "ytdl",
      "comments": 0
    }
  },
  
  "downloader": {
    "ytdl": {
      "format": "bv*[height<=720]+ba/b[height<=720]/bv*+ba/b",
      "cmdline-args": [
        "--format-sort-reset",
        "-S", "height:720,+size,+br",
        "--merge-output-format", "mp4"
      ]
    }
  }
}
